{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "co.skyclient.mart",
  "version": "2.0.0",
  "defaultMode": "window",
  "documentRoot": "/build/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "nativeAllowList": ["filesystem.*", "os.*", "storage.*"],
  "modes": {
    "window": {
      "title": "Mart",
      "width": 1000,
      "height": 500,
      "minWidth": 400,
      "minHeight": 200,
      "enableInspector": true,
      "icon": "/src/assets/icon.png"
    }
  },
  "cli": {
    "binaryName": "Mart",
    "resourcesPath": "/build/",
    "binaryVersion": "4.15.0",
    "frontendLibrary": {
      "patchFile": "/index-neutralino.html",
      "devUrl": "http://localhost:5173/index-neutralino.html"
    }
  }
}
